# Public site URL for canonical links, Open Graph, sitemap, and prerendered HTML (no trailing slash)
VITE_SITE_URL=https://tmaas.digitalqatalyst.com

# Set PRERENDER_SKIP=true to skip postbuild HTML prerender (faster local builds)
# PRERENDER_SKIP=true

# Supabase (local: run `npx supabase start` first)
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-anon-key

# Seed script only — never expose in the browser
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Microsoft Graph — contact form email (server-side only; also used by Vite dev API middleware)
MSGRAPH_TENANT_ID=
MSGRAPH_CLIENT_ID=
MSGRAPH_CLIENT_SECRET=
MSGRAPH_SENDER_UPN=
MSGRAPH_RECIPIENT_EMAIL=

# Cloudflare Turnstile — contact form bot protection (https://dash.cloudflare.com → Turnstile)
# Local dev test keys (always pass): site 1x00000000000000000000AA, secret 1x0000000000000000000000000000000AA
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
