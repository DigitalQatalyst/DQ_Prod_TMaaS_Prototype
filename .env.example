# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App — set NEXT_PUBLIC_ENV=production on Vercel production only (enables GA4)
NEXT_PUBLIC_ENV=development
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Customer workspace — set true to enable /dashboard/* routes locally
NEXT_PUBLIC_FEATURE_DASHBOARD=true

# Microsoft Entra External ID (CIAM) — customer sign-in
# Names match what is provisioned for TMaaS (AZURE_EXT_*).
AZURE_EXT_TENANT_ID=your-tenant-id
AZURE_EXT_CLIENT_ID=your-client-id
AZURE_EXT_CLIENT_SECRET=your-client-secret
AZURE_EXT_DOMAIN=your-tenant.ciamlogin.com
AZURE_EXT_USER_FLOW=YourSignUpSignInUserFlow
# Production callback — used when the app is not running on localhost.
AZURE_EXT_REDIRECT_URI=https://your-domain.com/customer/auth/callback
# Local callback — must match Entra Web redirect URI for localhost dev exactly.
AZURE_EXT_REDIRECT_URI_LOCAL=http://localhost:3000/customer/auth/callback
# Optional — defaults to openid,profile,email
# AZURE_EXT_SCOPES=openid,profile,email

# Session JWT — sign/verify the session_token cookie after auth callback
# Required in production. Generate with: openssl rand -hex 32
AUTH_SESSION_SECRET=generate-a-long-random-string
AUTH_SESSION_TTL_SECONDS=28800

# Legacy Entra OIDC names (optional fallback if AZURE_EXT_* not set)
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_ID=
# ENTRA_CLIENT_SECRET=
# ENTRA_REDIRECT_URI=http://localhost:3000/customer/auth/callback

# MS Graph — contact form email sending
MSGRAPH_TENANT_ID=your-tenant-id
MSGRAPH_CLIENT_ID=your-client-id
MSGRAPH_CLIENT_SECRET=your-client-secret
MSGRAPH_SENDER_UPN=sender@your-domain.com
MSGRAPH_RECIPIENT_EMAIL=recipient@your-domain.com
