# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App — set NEXT_PUBLIC_ENV=production on Vercel production only (enables GA4)
NEXT_PUBLIC_ENV=development
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Customer workspace — set true to enable /dashboard/* routes locally
NEXT_PUBLIC_FEATURE_DASHBOARD=true

# MS Graph — contact form email sending
MSGRAPH_TENANT_ID=your-tenant-id
MSGRAPH_CLIENT_ID=your-client-id
MSGRAPH_CLIENT_SECRET=your-client-secret
MSGRAPH_SENDER_UPN=sender@your-domain.com
MSGRAPH_RECIPIENT_EMAIL=recipient@your-domain.com
