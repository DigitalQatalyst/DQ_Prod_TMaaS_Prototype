{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src/App.css",
    "src/App.tsx",
    "src/assets",
    "src/components",
    "src/contexts",
    "src/data",
    "src/hooks",
    "src/index.css",
    "src/layouts",
    "src/lib",
    "src/main.tsx",
    "src/pages",
    "src/routes",
    "src/services",
    "src/test",
    "src/types",
    "src/utils",
    "src/vite-env.d.ts",
    "scratch",
    "workspace",
    "scripts"
  ]
}
